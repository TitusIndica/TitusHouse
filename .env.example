# Variaveis de ambiente do TitusHouse Hub
# Renomeie para .env e preencha

# Tag de afiliado da Amazon (obtida no cadastro Associates)
TAG_AMAZON=titusindica-20

# Tag de afiliado do Mercado Livre Parceiros (mf_id)
TAG_ML=

# Token de acesso para o painel admin (/admin)
# Inventa uma string longa e guarda com voce
ADMIN_TOKEN=troque-esta-string-por-uma-senha-forte-2026

# Turso (producao) - banco SQLite persistente
# Em dev/teste, deixar vazio usa o arquivo local ./data.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Frontend URL para CORS (vitrine public em /api)
# Em producao aponte para o GitHub Pages ou dominio propio
WEB_ORIGIN=

# Porta do servidor (Render injeta PORT automaticamente)
PORT=3000